# Copy to /etc/k2-preview/env on Ubuntu (chmod 600).
# Loaded by systemd at runtime — restart k2-preview after edits.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=
REGISTRATION_FROM_EMAIL=K2 Soccer Camp <noreply@k2soccercamp.com>
REGISTRATION_ADMIN_EMAIL=info@k2soccercamp.com

TURNSTILE_SECRET_KEY=

# Optional: same as SUPABASE_URL if not set elsewhere
# NODE_ENV=production
