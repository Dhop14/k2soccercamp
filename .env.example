# Copy to .env in the project root (local dev and Ubuntu build dir).

# --- Build-time (VITE_ — embedded in client bundle; safe to rebuild on server) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_TURNSTILE_SITE_KEY=

# --- Runtime (server only — see docs/DEPLOYMENT.md) ---
# Local dev: you can put these in .env; Vite/Nitro loads them for createServerFn.
# Ubuntu production: prefer /etc/k2-preview/env via systemd (not only .env).
# Page load works with URL + publishable key only; SUBMIT requires SERVICE_ROLE_KEY.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
REGISTRATION_FROM_EMAIL=K2 Soccer Camp <noreply@k2soccercamp.com>
REGISTRATION_ADMIN_EMAIL=info@k2soccercamp.com
TURNSTILE_SECRET_KEY=
